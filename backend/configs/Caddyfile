# Replace 'api.example.com' with your actual domain
# Example: api.yourdomain.com
#
# --- 502 + "CORS" in the browser ---
# If https://www.yoursite.com sees "No Access-Control-Allow-Origin" but Network shows 502,
# the API container (or Mongo) is usually down — Caddy's error page has no CORS headers.
# Fix: docker compose ps / logs api on the VPS; see docs-archive/CONTENT_AND_API_SAFETY.md
#
# Optional (Caddy 2.6+): add CORS on proxy error responses so DevTools shows the real status:
#   handle_errors {
#       header Access-Control-Allow-Origin "https://www.paradigmstudios.art"
#       header Access-Control-Allow-Credentials "true"
#       header Vary "Origin"
#       respond "{err.status_code} {err.status_text}"
#   }
# Place inside the site block, same level as handle / reverse_proxy (adjust origin to match site).

api.example.com {
    # API endpoints
    handle /api/* {
        reverse_proxy localhost:3000
    }
    
    # Media files
    handle /media/* {
        reverse_proxy localhost:3000
    }
    
    # Health check
    handle /health {
        reverse_proxy localhost:3000
    }
    
    encode gzip zstd
    log {
      output file /var/log/caddy/api_access.log
      format single_field common_log
    }
}

# Optional: MongoDB admin interface (secure this!)
# admin.example.com {
#   reverse_proxy localhost:8081
# }
