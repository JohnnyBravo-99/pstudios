# Legacy short template — for the full list of variables see `.env.example` in this folder.
PORT=3000
NODE_ENV=development
DATABASE_URL=mongodb://localhost:27017/pstudios
JWT_SECRET=your_jwt_secret_here
CLIENT_ORIGIN=http://localhost:3000
UPLOAD_DIR=./uploads

# Discord Bot Integration
DISCORD_BOT_API_KEY=your_secure_random_api_key_here

# Email (contact form + admin mail) — see docs-archive/EMAIL_SETUP.md
CONTACT_INTAKE_TO=jarnold@paradigmstudios.art
EMAIL_FROM=noreply@paradigmstudios.art

# Option 1: Gmail (dev)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Option 2: SMTP — Microsoft 365 / GoDaddy Email Essentials (see docs-archive/EMAIL_SETUP.md)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@paradigmstudios.art
# SMTP_PASSWORD=mailbox_or_app_password
#
# Option 3: SMTP — other providers (Hostinger mail, etc.)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# Optional: SMTP_PASSWORD_FILE=/usr/src/app/secrets/smtp_password.txt
