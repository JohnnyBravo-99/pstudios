# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_minimum_32_characters

# MongoDB Configuration
# For local development: mongodb://localhost:27017/paradigm_studios
# For Docker: mongodb://root:your_password@mongo:27017/paradigm_studios?authSource=admin
DATABASE_URL=mongodb://localhost:27017/paradigm_studios

# MongoDB Docker Configuration (if using Docker)
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=your_secure_password_here
MONGO_DATABASE=paradigm_studios

# Discord Bot API Key (for announcements feature)
DISCORD_BOT_API_KEY=your_discord_bot_api_key_here

# Email Configuration (optional)
# CONTACT_INTAKE_TO — inbox for public contact form on the marketing site
CONTACT_INTAKE_TO=jarnold@paradigmstudios.art
EMAIL_FROM=noreply@paradigmstudios.art
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# SMTP Configuration (alternative to Gmail)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
# Optional: read password from a file (Docker mount), instead of SMTP_PASSWORD
# SMTP_PASSWORD_FILE=/usr/src/app/secrets/smtp_password.txt

# File Upload Configuration
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3001,https://paradigmstudios.art,https://www.paradigmstudios.art
